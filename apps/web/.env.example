# Backend API base URL for server-side Next.js fetches (no trailing slash)
# Example (local backend in this repo): http://localhost:8089
H1B_API_BASE_URL=http://localhost:8089

# Public API base URL for client-side auth fetches/login redirects.
# Leave empty in production behind Caddy so the browser uses same-origin /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8089

# Site URL used for absolute URLs in sitemap/metadata (production)
NEXT_PUBLIC_SITE_URL=https://h1bfinder.com
